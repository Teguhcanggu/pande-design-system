{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/booking/**",
              "components/cards/**",
              "components/core/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Work Sans))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Work Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Amenity'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|note|style|key|ref|className|style|children)$/]",
        "message": "<Amenity> doesn't accept that prop. Declared props: icon, label, note, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BookingBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:onSubmit|defaultGuests|style|key|ref|className|style|children)$/]",
        "message": "<BookingBar> doesn't accept that prop. Declared props: onSubmit, defaultGuests, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|href|type|disabled|onDark|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, href, type, disabled, onDark, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:coral|ghost)$/]",
        "message": "<Button> variant must be one of 'coral' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Perk'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Perk> doesn't accept that prop. Declared props: icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Review'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|author|rating|style|key|ref|className|style|children)$/]",
        "message": "<Review> doesn't accept that prop. Declared props: quote, author, rating, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoomCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|alt|name|blurb|href|tag|span|style|key|ref|className|style|children)$/]",
        "message": "<RoomCard> doesn't accept that prop. Declared props: image, alt, name, blurb, href, tag, span, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoomCard'] > JSXAttribute[name.name='span'] > Literal[value!=/^(?:std|tall|wide)$/]",
        "message": "<RoomCard> span must be one of 'std' | 'tall' | 'wide'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
